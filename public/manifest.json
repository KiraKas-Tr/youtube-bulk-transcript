{
  "manifest_version": 3,
  "name": "Bulk YouTube Transcript Saver",
  "description": "Save public YouTube captions from up to 50 video URLs as Markdown, TXT, JSON, and reports.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://youtu.be/*"
  ],
  "action": {
    "default_title": "Bulk YouTube Transcript Saver"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "index.html"
}
